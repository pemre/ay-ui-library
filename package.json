{
    "name": "ay-ui-library",
    "version": "0.4.1",
    "description": "🌜 Ay UI Library — Reusable visualization and interactive components for React",
    "type": "module",
    "main": "dist/index.cjs.js",
    "module": "dist/index.es.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "storybook dev -p 6006",
        "build": "vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "biome check src",
